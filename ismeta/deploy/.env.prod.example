# ISMeta Production Environment
# Скопировать в .env.prod и заполнить реальными значениями.

# === Database ===
POSTGRES_DB=ismeta
POSTGRES_USER=ismeta
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === Redis ===
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# === Django ===
DJANGO_SECRET_KEY=CHANGE_ME_DJANGO_SECRET
ALLOWED_HOSTS=ismeta.hvac-info.com,localhost

# === ERP Integration ===
# ERP backend на том же сервере — через localhost
ISMETA_ERP_BASE_URL=http://127.0.0.1:8000
ISMETA_ERP_MASTER_TOKEN=CHANGE_ME_SHARED_SECRET
ISMETA_ERP_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# === JWT (должен совпадать с ERP settings.ISMETA_JWT_SECRET) ===
ISMETA_JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS

# === LLM ===
OPENAI_API_KEY=sk-...
ISMETA_LLM_MODE=real
# ISMETA_LLM_MODE=mock  # если без LLM на старте
