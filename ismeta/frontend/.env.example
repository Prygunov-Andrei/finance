# Frontend env. Скопируй как .env.local.

# ==== API ====
NEXT_PUBLIC_ISMETA_API_URL=http://localhost:8001/api/v1

# ==== Feature flags ====
NEXT_PUBLIC_FEATURE_AGENT=true
NEXT_PUBLIC_FEATURE_EXCEL_ROUNDTRIP=true
NEXT_PUBLIC_FEATURE_PUBLIC_MODE=false   # этап 2

# ==== Dev ====
NEXT_PUBLIC_DEFAULT_WORKSPACE=11111111-1111-1111-1111-111111111111
NEXT_PUBLIC_DEV_USER_TOKEN_OVERRIDE=  # опционально, для отладки без ERP
