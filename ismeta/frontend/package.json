{
  "name": "ismeta-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "ISMeta frontend — Next.js приложение для работы со сметами.",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "15.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@tanstack/react-query": "^5.51.0",
    "@tanstack/react-table": "^8.21.0",
    "@tanstack/react-virtual": "^3.10.0",
    "@hello-pangea/dnd": "^18.0.0",
    "xlsx": "^0.18.5",
    "next-themes": "^0.3.0",
    "next-intl": "^3.17.0",
    "sonner": "^1.5.0",
    "zod": "^3.23.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.9.0",
    "eslint-config-next": "15.0.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "vitest": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@playwright/test": "^1.47.0",
    "tsup": "^8.2.0"
