# Скопируй как .env.local, заполни значения для локальной разработки.
# Для production используется secret-менеджер (см. specs/12-security.md).

# ==== Django ====
DJANGO_SECRET_KEY=dev-secret-change-me-in-production
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# ==== База данных ====
DATABASE_URL=postgres://ismeta:ismeta@localhost:5432/ismeta

# ==== Redis ====
# БД 2 — основная, БД 3 — Celery
REDIS_URL=redis://localhost:6379/2
CELERY_BROKER_URL=redis://localhost:6379/3
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# ==== ERP интеграция ====
ERP_BASE_URL=http://localhost:8000
ERP_CATALOG_BASE_URL=http://localhost:8000
ERP_MASTER_TOKEN=dev-master-token-change-me
ERP_WEBHOOK_SECRET=dev-webhook-secret-change-me

# ==== Recognition Service (E15.02b) ====
# Standalone микросервис распознавания PDF (recognition/ в корне монорепо).
# В compose — http://recognition:8003; локально — http://localhost:8003.
RECOGNITION_URL=http://recognition:8003
# shared secret — совпадает с RECOGNITION_API_KEY у recognition-сервиса
RECOGNITION_API_KEY=dev-recognition-key-change-me

# устаревшие переменные (E15.01 pre-microservice) — больше не используются:
# RECOGNITION_BASE_URL, RECOGNITION_MODE, RECOGNITION_MOCK_URL

# ==== LLM ====
LLM_PROVIDER_DEFAULT=openai
LLM_MODE=real  # real | cassette | mock
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
GROK_API_KEY=

# Модели
LLM_MODEL_DEFAULT=gpt-4o
LLM_MODEL_AGENT_CHAT=gpt-4o
LLM_MODEL_MATCHING_SEMANTIC=gpt-4o
LLM_MODEL_MATCHING_WEB=gemini-2.0-flash-exp

# Бюджет (₽/мес) — при превышении LLM-вызовы блокируются
LLM_MONTHLY_BUDGET_RUB=5000
LLM_TARGET_COST_PER_ESTIMATE_RUB=50

# ==== Seed workspace UUIDs для dev ====
WORKSPACE_DEV_SEED_UUIDS=11111111-1111-1111-1111-111111111111,22222222-2222-2222-2222-222222222222

# ==== Secrets ====
# В коробке использовать sops или аналог; здесь — для dev
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
ISMETA_WEBHOOK_SIGNING_KEY=dev-ismeta-webhook-key

# ==== Файлы ====
MEDIA_ROOT=./media
UPLOAD_MAX_SIZE_MB=50

# ==== Логирование ====
LOG_LEVEL=DEBUG
LOG_FORMAT=json  # json | text

# ==== Sentry (опционально) ====
SENTRY_DSN=

# ==== Прочее ====
KNOWLEDGE_MD_ROOT=./data/knowledge

# ==== OpenTelemetry / Observability ====
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # Jaeger/Tempo/SigNoz
OTEL_SERVICE_NAME=ismeta-backend
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1   # 10% sampling в prod
