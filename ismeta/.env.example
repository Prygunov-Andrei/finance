# ISMeta — сводный .env для docker-compose оркестрации.
# Скопируй как `.env` рядом с docker-compose.yml.
# Переменные разработчика (не-compose) см. в backend/.env.example и frontend/.env.example.

# Порты намеренно нестандартные, чтобы ISMeta работала параллельно с ERP
# (ERP занимает 5432/6379/8000/3000). Внутри контейнеров порты стандартные,
# маппинг host→container переопределяется только host-side.

# ==== Postgres ====
POSTGRES_DB=ismeta
POSTGRES_USER=ismeta
POSTGRES_PASSWORD=ismeta
POSTGRES_PORT=5433

# ==== Redis ====
REDIS_PORT=6380

# ==== Backend ====
BACKEND_PORT=8001
DJANGO_SECRET_KEY=dev-secret-change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,ismeta-backend
LOG_LEVEL=INFO
LOG_FORMAT=text
# Для dev OTEL отключён чтобы не лить в /dev/null экспортёра
OTEL_ENABLED=false

# ==== Frontend ====
FRONTEND_PORT=3001
NEXT_PUBLIC_ISMETA_API_URL=http://localhost:8001/api/v1
NEXT_PUBLIC_DEFAULT_WORKSPACE=11111111-1111-1111-1111-111111111111
NEXT_PUBLIC_FEATURE_AGENT=true
NEXT_PUBLIC_FEATURE_EXCEL_ROUNDTRIP=true
NEXT_PUBLIC_FEATURE_PUBLIC_MODE=false

# ==== Recognition Service (E15.02b) ====
# URL видим из ismeta-backend контейнера (docker internal DNS)
RECOGNITION_URL=http://recognition:8003
# shared secret — совпадает с RECOGNITION_API_KEY у сервиса recognition
RECOGNITION_API_KEY=dev-recognition-key-change-me
# TD-04: LLM API key (OpenAI / DeepSeek / Claude OpenAI-compatible).
# Имя нейтральное; провайдер выбирается через OPENAI_API_BASE.
LLM_API_KEY=
# DEPRECATED: backward-compat alias, читается если LLM_API_KEY пуст.
# OPENAI_API_KEY=

# ==== LLM Profiles (E18-2) ====
# Fernet-ключ для шифрования api_key в LLMProfile (БД).
# Генерация:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Без ключа CRUD профилей упадёт с ImproperlyConfigured 500.
# ВАЖНО: смена ключа делает все существующие api_key_encrypted нечитаемыми.
LLM_PROFILE_ENCRYPTION_KEY=

# ==== Recognition jobs (E19-2) ====
# URL backend'а из контейнеров recognition / recognition-worker для callbacks.
BACKEND_INTERNAL_URL=http://ismeta-backend:8000
# Сколько одновременных PDF расшифровываются — глобально по worker'у.
RECOGNITION_MAX_PARALLEL_JOBS=2
# Интервал опроса очереди queued job'ов (секунды).
RECOGNITION_WORKER_POLL_INTERVAL=2.0
